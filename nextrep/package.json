{
  "name": "nextrep",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@nextrep/api",
    "dev:mobile": "turbo run dev --filter=@nextrep/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@nextrep/api",
    "db:migrate": "turbo run db:migrate --filter=@nextrep/api",
    "db:seed": "turbo run db:seed --filter=@nextrep/api",
    "db:studio": "turbo run db:studio --filter=@nextrep/api",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}

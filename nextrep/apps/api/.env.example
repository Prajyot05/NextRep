# NextRep Backend Environment Variables

# Neon PostgreSQL connection string
# Get from: https://neon.tech → your project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/nextrep?sslmode=require

# JWT secret — generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_64_byte_random_hex_string

# Cloudflare R2 (optional — for photo/video uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nextrep-media
R2_PUBLIC_URL=

# Server
PORT=3000
NODE_ENV=development
